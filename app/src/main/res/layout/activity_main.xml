<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NOTHING · BUDGET"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:letterSpacing="0.25"
                android:fontFamily="monospace" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/theme_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/theme_auto"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textSize="10sp"
                    android:text="Auto" />
                <Button
                    android:id="@+id/theme_light"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textSize="10sp"
                    android:text="Light" />
                <Button
                    android:id="@+id/theme_dark"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textSize="10sp"
                    android:text="Dark" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/permission_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:padding="14dp"
            android:background="@color/surface_alt"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS permission needed"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required to read bank notifications. Stays on-device."
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp" />
            <Button
                android:id="@+id/btn_grant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grant"
                android:layout_marginTop="10dp"
                android:textColor="@color/btn_fg"
                android:backgroundTint="@color/btn_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:id="@+id/btn_session_picker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/session_picker_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set up budget"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_new_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ New"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/btn_subtle_bg"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMAINING"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"
            android:layout_marginTop="22dp" />

        <TextView
            android:id="@+id/summary_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AED 0"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPENT"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/summary_spent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="− 0"
                    android:textColor="@color/expense"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECEIVED"
                    android:textColor="@color/text_hint"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/summary_received"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ 0"
                    android:textColor="@color/income"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUDGET"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace" />

        <LinearLayout
            android:id="@+id/budget_display_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/budget_display_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btn_edit_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/btn_subtle_bg"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/budget_edit_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/input_budget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="3000"
                android:fontFamily="monospace"
                android:textSize="18sp"
                android:backgroundTint="@color/text_primary"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/btn_save_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textColor="@color/btn_fg"
                android:backgroundTint="@color/btn_bg"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TRANSACTIONS"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/btn_subtle_bg"
                android:textSize="11sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_transactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:overScrollMode="never" />
    </LinearLayout>
</ScrollView>
